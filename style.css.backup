/* Hide modal by default */
.modal {
    display: none;
}
/* ========================================
   HOPE FOUNDATION - NGO WEBSITE STYLES
   Modern, Professional, Responsive Design
   ======================================== */

/* ========== GLOBAL STYLES ========== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary-blue: #1e40af;
    --light-blue: #3b82f6;
    --accent-yellow: #fbbf24;
    --dark-yellow: #f59e0b;
    --dark-bg: #1f2937;
    --light-bg: #f9fafb;
    --text-dark: #111827;
    --text-light: #6b7280;
    --white: #ffffff;
    --shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    --shadow-hover: 0 15px 40px rgba(0, 0, 0, 0.15);
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Poppins', sans-serif;
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
    background: var(--white);
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* ========== NAVIGATION BAR ========== */
header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 20px 0;
    background: rgba(30, 64, 175, 0.95);
    backdrop-filter: blur(15px);
    z-index: 1000;
    transition: all 0.4s ease;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
}

header.scrolled {
    padding: 12px 0;
    background: rgba(30, 64, 175, 0.98);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
}

header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--white);
    font-size: 24px;
    font-weight: 700;
    cursor: pointer;
}

.logo i {
    font-size: 28px;
    color: var(--accent-yellow);
}

nav {
    display: flex;
    gap: 30px;
    align-items: center;
}

nav a {
    color: var(--white);
    text-decoration: none;
    font-weight: 500;
    font-size: 16px;
    transition: all 0.3s ease;
    position: relative;
}

nav a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-yellow);
    transition: width 0.3s ease;
}

nav a:hover::after,
nav a.active::after {
    width: 100%;
}

nav a:hover {
    color: var(--accent-yellow);
}

.mobile-menu-toggle {
    display: none;
    color: var(--white);
    font-size: 24px;
    cursor: pointer;
}

/* ========== HERO SECTION ========== */
.hero-section {
    height: 100vh;
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(30, 64, 175, 0.85), rgba(59, 130, 246, 0.75)),
                url('https://images.unsplash.com/photo-1509099836639-18ba1795216d?w=1920') center/cover;
    background-attachment: fixed;
    color: var(--white);
    text-align: center;
    overflow: hidden;
    margin: 0;
    padding: 0;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
}

.hero-content {
    position: relative;
    z-index: 2;
    padding: 0 20px;
    animation: fadeInUp 1s ease;
    max-width: 900px;
    margin: 0 auto;
}

.hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 64px;
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.2;
    text-shadow: 2px 4px 10px rgba(0, 0, 0, 0.3);
}

.hero-subtitle {
    font-size: 22px;
    margin-bottom: 40px;
    font-weight: 300;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
}

.hero-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 50px;
}

.btn-hero {
    padding: 18px 50px;
    font-size: 18px;
    box-shadow: 0 10px 30px rgba(251, 191, 36, 0.4);
}

.hero-stats {
    display: flex;
    gap: 60px;
    justify-content: center;
    align-items: center;
    margin-top: 20px;
    flex-wrap: wrap;
}

.hero-stat-item {
    text-align: center;
    padding: 20px 30px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
}

.hero-stat-item:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-5px);
}

.hero-stat-item h3 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 5px;
    color: var(--accent-yellow);
}

.hero-stat-item p {
    font-size: 14px;
    opacity: 0.9;
    font-weight: 500;
}

.btn {
    padding: 15px 40px;
    border: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
}

.btn:hover::before {
    width: 300px;
    height: 300px;
}

.btn-primary {
    background: var(--accent-yellow);
    color: var(--text-dark);
    box-shadow: 0 8px 20px rgba(251, 191, 36, 0.35);
}

.btn-primary:hover {
    background: var(--dark-yellow);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(251, 191, 36, 0.5);
}

.btn-secondary {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
}

.btn-secondary:hover {
    background: var(--white);
    color: var(--primary-blue);
}

.scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
    font-size: 24px;
    color: var(--white);
    opacity: 0.7;
}

/* ========== SECTION STYLES ========== */
.section {
    padding: 100px 0;
    position: relative;
}

.section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(30, 64, 175, 0.1) 50%, transparent 100%);
}

.section-alt {
    background: var(--light-bg);
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-tag {
    display: inline-block;
    background: rgba(30, 64, 175, 0.1);
    color: var(--primary-blue);
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 15px;
}

.section-header h2 {
    font-size: 42px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 15px;
}

.section-description {
    font-size: 18px;
    color: var(--text-light);
    max-width: 600px;
    margin: 0 auto;
}

/* ========== ABOUT SECTION ========== */
.about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
}

.about-text h3 {
    font-size: 28px;
    color: var(--primary-blue);
    margin-bottom: 15px;
    margin-top: 30px;
}

.about-text h3:first-child {
    margin-top: 0;
}

.about-text p {
    color: var(--text-light);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 20px;
}

.mission-list {
    list-style: none;
    margin: 20px 0;
}

.mission-list li {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 12px 0;
    color: var(--text-light);
    font-size: 16px;
}

.mission-list i {
    color: var(--accent-yellow);
    font-size: 20px;
}

/* ========== RECENT DONATIONS (Moved Ticker) STYLES ========== */
/* Modern card container for the moved donation ticker. Keeps blue + yellow theme. */
.recent-donations-section .recent-donations-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(249,250,251,0.98));
    padding: 22px;
    border-radius: 14px;
    box-shadow: var(--shadow);
    border: 1px solid rgba(30,64,175,0.06);
    max-width: 1100px;
    margin: 0 auto 40px auto;
}

.recent-donations-section .recent-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
}

.recent-donations-section .recent-header h2 {
    color: var(--primary-blue);
    font-size: 28px;
    margin: 0;
    font-weight: 700;
}

.recent-donations-section .recent-header .section-description {
    margin-top: 4px;
    color: var(--text-light);
    font-size: 15px;
    max-width: 720px;
}

.donation-ticker {
    background: linear-gradient(90deg, rgba(59,130,246,0.04), rgba(251,191,36,0.02));
    padding: 12px 14px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    overflow: hidden;
    border: 1px solid rgba(30,64,175,0.04);
}

.ticker-content {
    display: flex;
    gap: 14px;
    align-items: center;
    white-space: nowrap;
    /* subtle left-to-right continuous scroll on wide screens */
    animation: scrollTicker 20s linear infinite;
}

.ticker-item {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 8px 12px;
    background: rgba(255,255,255,0.9);
    border-radius: 10px;
    border: 1px solid rgba(30,64,175,0.06);
    box-shadow: 0 8px 20px rgba(30,64,175,0.03);
    color: var(--text-dark);
    font-weight: 600;
    font-size: 14px;
}

.ticker-item .donor-name {
    color: var(--primary-blue);
}

.ticker-item .donation-amount {
    color: var(--accent-yellow);
    font-weight: 700;
    margin-left: 6px;
}

@keyframes scrollTicker {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
}

/* Responsive adjustments */
@media (max-width: 900px) {
    .recent-donations-section .recent-donations-card { padding: 18px; }
    .recent-donations-section .recent-header h2 { font-size: 24px; text-align: left; }
}

@media (max-width: 640px) {
    .recent-donations-section .recent-header { align-items: center; text-align: center; }
    .recent-donations-section .recent-header h2 { width: 100%; }
    .ticker-content { animation: none; flex-wrap: wrap; justify-content: center; }
    .donation-ticker { padding: 12px; }
    .ticker-item { font-size: 13px; }
}

/* Accessibility: reduce motion preference */
@media (prefers-reduced-motion: reduce) {
    .ticker-content { animation: none !important; }
}

.about-stats-mini {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 30px;
}

.stat-mini {
    text-align: center;
}

.stat-mini h4 {
    font-size: 32px;
    color: var(--primary-blue);
    margin-bottom: 5px;
}

.stat-mini p {
    font-size: 14px;
    color: var(--text-light);
}

.about-image {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow);
}

.about-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
}

.image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(30, 64, 175, 0.8), rgba(251, 191, 36, 0.6));
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.about-image:hover .image-overlay {
    opacity: 1;
}

.image-overlay i {
    font-size: 60px;
    color: var(--white);
}

/* ========== CAUSES SECTION ========== */
.causes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
}

.cause-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.08);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid transparent;
}

.cause-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 45px rgba(30, 64, 175, 0.15);
    border-color: var(--accent-yellow);
}

.cause-image {
    position: relative;
    height: 220px;
    overflow: hidden;
}

.cause-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.cause-card:hover .cause-image img {
    transform: scale(1.1);
}

.cause-icon {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 60px;
    height: 60px;
    background: var(--accent-yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--white);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
}

.cause-content {
    padding: 30px;
}

.cause-content h3 {
    font-size: 24px;
    color: var(--text-dark);
    margin-bottom: 15px;
}

.cause-content p {
    color: var(--text-light);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 20px;
}

.cause-progress {
    margin: 25px 0;
}

.progress-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 14px;
    color: var(--text-light);
    font-weight: 500;
}

.progress-bar-container {
    width: 100%;
    height: 8px;
    background: #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
}

.progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-blue), var(--light-blue));
    border-radius: 10px;
    transition: width 1s ease;
}

.btn-cause {
    width: 100%;
    background: var(--primary-blue);
    color: var(--white);
    padding: 12px;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-cause:hover {
    background: var(--light-blue);
    transform: translateY(-2px);
}

/* ========== IMPACT SECTION ========== */
.impact-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 60px;
}

.stat-card {
    background: var(--white);
    padding: 40px 30px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.08);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(30, 64, 175, 0.05), rgba(251, 191, 36, 0.05));
    opacity: 0;
    transition: opacity 0.3s ease;
}

.stat-card:hover::before {
    opacity: 1;
}

.stat-card:hover {
    transform: translateY(-12px) scale(1.02);
    box-shadow: 0 20px 45px rgba(30, 64, 175, 0.15);
    border-color: var(--accent-yellow);
}

.stat-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 32px;
    color: var(--white);
}

.stat-number {
    font-size: 48px;
    font-weight: 700;
    color: var(--primary-blue);
    margin-bottom: 10px;
}

.stat-card p {
    font-size: 16px;
    color: var(--text-light);
    font-weight: 500;
}

/* Overall Progress */
.overall-progress {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--light-blue) 100%);
    padding: 60px 50px;
    border-radius: 25px;
    color: var(--white);
    text-align: center;
    margin-bottom: 60px;
    box-shadow: 0 15px 40px rgba(30, 64, 175, 0.25);
    position: relative;
    overflow: hidden;
}

.overall-progress::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.1) 0%, transparent 70%);
    animation: rotate 20s linear infinite;
}

@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.overall-progress > * {
    position: relative;
    z-index: 1;
}

.overall-progress h3 {
    font-size: 28px;
    margin-bottom: 30px;
}

.progress-info-large {
    display: flex;
    justify-content: center;
    gap: 80px;
    margin-bottom: 30px;
}

.progress-info-large > div {
    text-align: center;
}

.amount-raised,
.amount-goal {
    font-size: 42px;
    font-weight: 700;
    display: block;
    margin-bottom: 5px;
}

.progress-info-large small {
    font-size: 16px;
    opacity: 0.9;
}

.progress-bar-large {
    width: 100%;
    height: 20px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 50px;
    overflow: hidden;
    margin-bottom: 15px;
}

.progress-fill {
    height: 100%;
    background: var(--accent-yellow);
    border-radius: 50px;
    transition: width 2s ease;
}

.progress-percentage {
    font-size: 24px;
    font-weight: 600;
}

/* Success Stories */
.success-stories {
    margin-bottom: 60px;
}

.stories-title {
    font-size: 32px;
    text-align: center;
    margin-bottom: 40px;
    color: var(--text-dark);
}

.stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.story-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.08);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid transparent;
}

.story-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 45px rgba(30, 64, 175, 0.15);
    border-color: var(--accent-yellow);
}

.story-card img {
    width: 100%;
    height: 250px;
    object-fit: cover;
}

.story-content {
    padding: 30px;
}

.story-content h4 {
    font-size: 20px;
    color: var(--text-dark);
    margin-bottom: 15px;
}

.story-content p {
    color: var(--text-light);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 15px;
    font-style: italic;
}

.story-author {
    display: block;
    color: var(--primary-blue);
    font-weight: 600;
    font-size: 14px;
}

/* Recent Donations */
.recent-donations {
    background: linear-gradient(135deg, #ffffff 0%, #f9fafb 100%);
    padding: 50px;
    border-radius: 25px;
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.08);
    border: 2px solid rgba(30, 64, 175, 0.05);
}

.recent-donations h3 {
    font-size: 28px;
    margin-bottom: 30px;
    text-align: center;
    color: var(--text-dark);
}

.donations-list {
    display: grid;
    gap: 15px;
}

.donation-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px;
    background: var(--white);
    border-radius: 15px;
    border-left: 4px solid var(--accent-yellow);
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.06);
    transition: all 0.3s ease;
}

.donation-item:hover {
    transform: translateX(8px);
    box-shadow: 0 8px 20px rgba(30, 64, 175, 0.12);
}

.donor-info {
    display: flex;
    align-items: center;
    gap: 15px;
}

.donor-avatar {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-weight: 600;
    font-size: 18px;
}

.donor-details h4 {
    font-size: 16px;
    color: var(--text-dark);
    margin-bottom: 3px;
}

.donor-details p {
    font-size: 13px;
    color: var(--text-light);
}

.donation-amount {
    font-size: 20px;
    font-weight: 700;
    color: var(--primary-blue);
}

/* ========== TESTIMONIALS SECTION ========== */
.testimonials-section {
    overflow: hidden;
}

.testimonials-carousel {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
}

.testimonials-wrapper {
    display: flex;
    transition: transform 0.5s ease;
}

.testimonial-slide {
    min-width: 100%;
    padding: 50px;
    text-align: center;
}

.testimonial-content {
    background: var(--white);
    padding: 50px;
    border-radius: 25px;
    box-shadow: 0 15px 40px rgba(30, 64, 175, 0.1);
    position: relative;
    border: 2px solid rgba(30, 64, 175, 0.05);
    transition: all 0.3s ease;
}

.testimonial-content:hover {
    box-shadow: 0 20px 50px rgba(30, 64, 175, 0.15);
    transform: translateY(-5px);
}

.quote-icon {
    font-size: 60px;
    color: var(--accent-yellow);
    opacity: 0.3;
    position: absolute;
    top: 20px;
    left: 30px;
}

.testimonial-text {
    font-size: 20px;
    font-style: italic;
    color: var(--text-dark);
    line-height: 1.8;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
}

.testimonial-author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
}

.author-image {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent-yellow);
}

.author-info h4 {
    font-size: 18px;
    color: var(--text-dark);
    margin-bottom: 5px;
}

.author-info p {
    font-size: 14px;
    color: var(--text-light);
}

.carousel-controls {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
}

.carousel-btn {
    width: 55px;
    height: 55px;
    background: var(--primary-blue);
    color: var(--white);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 20px;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 5px 15px rgba(30, 64, 175, 0.3);
}

.carousel-btn:hover {
    background: var(--light-blue);
    transform: scale(1.15);
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.4);
}

.carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 20px;
}

.dot {
    width: 12px;
    height: 12px;
    background: #d1d5db;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
}

.dot.active {
    background: var(--primary-blue);
    width: 30px;
    border-radius: 10px;
}

/* ========== VOLUNTEER SECTION ========== */
.volunteer-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
}

.volunteer-info h3 {
    font-size: 28px;
    color: var(--text-dark);
    margin-bottom: 25px;
}

.volunteer-benefits {
    list-style: none;
    margin-bottom: 40px;
}

.volunteer-benefits li {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 0;
    font-size: 16px;
    color: var(--text-light);
}

.volunteer-benefits i {
    color: var(--accent-yellow);
    font-size: 20px;
}

.volunteer-quote {
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    padding: 30px;
    border-radius: 15px;
    color: var(--white);
    position: relative;
}

.volunteer-quote i {
    font-size: 40px;
    opacity: 0.3;
    margin-bottom: 15px;
}

.volunteer-quote p {
    font-size: 18px;
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 15px;
}

.volunteer-quote span {
    display: block;
    font-size: 14px;
    opacity: 0.9;
}

/* Forms */
.volunteer-form,
.contact-form {
    background: var(--white);
    padding: 45px;
    border-radius: 25px;
    box-shadow: 0 10px 35px rgba(30, 64, 175, 0.1);
    border: 2px solid rgba(30, 64, 175, 0.05);
    transition: all 0.3s ease;
}

.volunteer-form:hover,
.contact-form:hover {
    box-shadow: 0 15px 45px rgba(30, 64, 175, 0.15);
    border-color: rgba(30, 64, 175, 0.1);
}

.volunteer-form h3,
.contact-form h3 {
    font-size: 24px;
    color: var(--text-dark);
    margin-bottom: 30px;
    text-align: center;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dark);
    margin-bottom: 8px;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    font-size: 15px;
    font-family: 'Poppins', sans-serif;
    transition: all 0.3s ease;
    background: var(--white);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 4px rgba(30, 64, 175, 0.1);
    transform: translateY(-2px);
}

.btn-full {
    width: 100%;
    padding: 15px;
    font-size: 16px;
}

/* ========== DONATE SECTION ========== */
.donate-section {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
}

.donation-showcase {
    max-width: 1000px;
    margin: 0 auto;
}

.donation-impact-centered {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 25px;
    margin-bottom: 60px;
    justify-items: center;
}

.impact-item {
    background: var(--white);
    padding: 35px 25px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 8px 25px rgba(30, 64, 175, 0.08);
    transition: all 0.4s ease;
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
}

.impact-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--primary-blue), var(--accent-yellow));
    transform: scaleX(0);
    transition: transform 0.3s ease;
}

.impact-item:hover::before {
    transform: scaleX(1);
}

.impact-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(30, 64, 175, 0.15);
    border-color: var(--accent-yellow);
}

.impact-icon {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 30px;
    color: var(--white);
    box-shadow: 0 5px 15px rgba(30, 64, 175, 0.3);
}

.impact-amount {
    font-size: 40px;
    font-weight: 700;
    color: var(--primary-blue);
    margin-bottom: 12px;
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.impact-item p {
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.6;
}

.donate-cta-centered {
    text-align: center;
    background: var(--white);
    padding: 50px;
    border-radius: 25px;
    box-shadow: 0 15px 40px rgba(30, 64, 175, 0.1);
    max-width: 700px;
    margin: 0 auto;
}

.btn-large {
    padding: 20px 60px;
    font-size: 19px;
    font-weight: 700;
}

.btn-pulse {
    animation: pulse 2s infinite;
}

.tax-benefit {
    margin-top: 25px;
    font-size: 15px;
    color: var(--text-dark);
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.tax-benefit i {
    color: var(--primary-blue);
}

.trust-badges {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-top: 25px;
    flex-wrap: wrap;
}

.trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--light-bg);
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    color: var(--primary-blue);
    border: 1px solid rgba(30, 64, 175, 0.1);
}

.trust-badge i {
    font-size: 16px;
}

/* ========== CONTACT SECTION ========== */
.contact-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 60px;
}

.contact-item {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
}

.contact-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--white);
    flex-shrink: 0;
}

.contact-item h4 {
    font-size: 18px;
    color: var(--text-dark);
    margin-bottom: 8px;
}

.contact-item p {
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.6;
}

/* ========== NEWSLETTER SECTION ========== */
.newsletter-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
}

.newsletter-text h3 {
    font-size: 28px;
    color: var(--text-dark);
    margin-bottom: 10px;
}

.newsletter-text p {
    font-size: 16px;
    color: var(--text-light);
}

.newsletter-form {
    display: flex;
    gap: 15px;
    flex: 1;
    max-width: 500px;
}

.newsletter-form input {
    flex: 1;
    padding: 15px 20px;
    border: 2px solid #e5e7eb;
    border-radius: 50px;
    font-size: 15px;
    font-family: 'Poppins', sans-serif;
}

.newsletter-form input:focus {
    outline: none;
    border-color: var(--primary-blue);
}

.newsletter-form button {
    padding: 15px 40px;
    white-space: nowrap;
}

/* ========== FOOTER ========== */
.footer {
    background: var(--dark-bg);
    color: var(--white);
    padding: 60px 0 30px;
}

.footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
}

.footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 20px;
}

.footer-logo i {
    font-size: 28px;
    color: var(--accent-yellow);
}

.footer-col p {
    color: #9ca3af;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
}

.social-links {
    display: flex;
    gap: 15px;
}

.social-links a {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    transition: all 0.3s ease;
}

.social-links a:hover {
    background: var(--accent-yellow);
    color: var(--dark-bg);
    transform: translateY(-3px);
}

.footer-col h4 {
    font-size: 18px;
    margin-bottom: 20px;
}

.footer-col ul {
    list-style: none;
}

.footer-col ul li {
    margin-bottom: 12px;
}

.footer-col ul li a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
}

.footer-col ul li a:hover {
    color: var(--accent-yellow);
    padding-left: 5px;
}

.footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-bottom p {
    color: #9ca3af;
    font-size: 14px;
}

/* ========== MODAL ========== */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.modal.active {
    display: flex !important;
}

.modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
}

.modal-content {
    position: relative;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    padding: 45px;
    border-radius: 25px;
    max-width: 520px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    animation: modalSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    background: #f3f4f6;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    color: var(--text-dark);
    transition: all 0.3s ease;
}

.modal-close:hover {
    background: #e5e7eb;
    transform: rotate(90deg);
}

.modal-header {
    text-align: center;
    margin-bottom: 30px;
}

.modal-icon {
    font-size: 60px;
    color: var(--accent-yellow);
    margin-bottom: 20px;
    animation: heartBeat 1.5s infinite;
}

@keyframes heartBeat {
    0%, 100% { transform: scale(1); }
    10%, 30% { transform: scale(1.1); }
    20%, 40% { transform: scale(0.95); }
}

.modal-header h3 {
    font-size: 28px;
    color: var(--text-dark);
    margin-bottom: 10px;
}

.modal-header p {
    font-size: 15px;
    color: var(--text-light);
}

.quick-amounts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 10px;
}

.amount-btn {
    padding: 10px;
    background: var(--light-bg);
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-dark);
    cursor: pointer;
    transition: all 0.3s ease;
}

.amount-btn:hover,
.amount-btn.active {
    background: var(--primary-blue);
    color: var(--white);
    border-color: var(--primary-blue);
}

/* ========== SUCCESS MESSAGE ========== */
.success-message {
    position: fixed;
    top: 100px;
    right: 30px;
    background: #10b981;
    color: var(--white);
    padding: 20px 30px;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    gap: 15px;
    z-index: 3000;
    transform: translateX(400px);
    opacity: 0;
    transition: all 0.3s ease;
}

.success-message.show {
    transform: translateX(0);
    opacity: 1;
}

.success-message i {
    font-size: 24px;
}

.success-message p {
    font-size: 15px;
    font-weight: 500;
}

/* ========== ANIMATIONS ========== */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes bounce {
    0%, 100% {
        transform: translateX(-50%) translateY(0);
    }
    50% {
        transform: translateX(-50%) translateY(-10px);
    }
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: scale(0.8) translateY(30px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

@keyframes pulse {
    0%, 100% {
        box-shadow: 0 10px 30px rgba(251, 191, 36, 0.4);
    }
    50% {
        box-shadow: 0 10px 40px rgba(251, 191, 36, 0.6);
    }
}

/* ========== RESPONSIVE DESIGN ========== */
@media (max-width: 1024px) {
    .about-content,
    .volunteer-content,
    .contact-content {
        grid-template-columns: 1fr;
    }
    
    .footer-content {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 768px) {
    /* Navigation */
    nav {
        position: fixed;
        top: 80px;
        left: -100%;
        width: 100%;
        height: calc(100vh - 80px);
        background: rgba(30, 64, 175, 0.98);
        flex-direction: column;
        padding: 50px 0;
        transition: left 0.3s ease;
    }
    
    nav.active {
        left: 0;
    }
    
    .mobile-menu-toggle {
        display: block;
    }
    
    /* Hero */
    .hero-title {
        font-size: 38px;
    }
    
    .hero-subtitle {
        font-size: 17px;
    }
    
    .hero-buttons {
        flex-direction: column;
        margin-bottom: 40px;
    }
    
    .btn-hero {
        padding: 16px 40px;
        font-size: 16px;
    }
    
    .hero-stats {
        gap: 20px;
    }
    
    .hero-stat-item {
        padding: 15px 20px;
    }
    
    .hero-stat-item h3 {
        font-size: 24px;
    }
    
    /* Sections */
    .section-header h2 {
        font-size: 32px;
    }
    
    .causes-grid,
    .stories-grid {
        grid-template-columns: 1fr;
    }
    
    .donation-impact-centered {
        grid-template-columns: 1fr;
    }
    
    .impact-stats {
        grid-template-columns: 1fr 1fr;
    }
    
    .form-row {
        grid-template-columns: 1fr;
    }
    
    .newsletter-content {
        flex-direction: column;
        text-align: center;
    }
    
    .newsletter-form {
        flex-direction: column;
        max-width: 100%;
    }
    
    .footer-content {
        grid-template-columns: 1fr;
    }
    
    .progress-info-large {
        gap: 40px;
    }
    
    .amount-raised,
    .amount-goal {
        font-size: 32px;
    }
    
    .donate-cta-centered {
        padding: 35px 25px;
    }
    
    .btn-large {
        padding: 16px 40px;
        font-size: 16px;
    }
}

@media (max-width: 480px) {
    .hero-title {
        font-size: 30px;
    }
    
    .hero-subtitle {
        font-size: 15px;
    }
    
    .hero-stats {
        gap: 15px;
        flex-direction: column;
    }
    
    .hero-stat-item {
        width: 100%;
        max-width: 280px;
    }
    
    .section {
        padding: 60px 0;
    }
    
    .section-header h2 {
        font-size: 26px;
    }
    
    .impact-stats {
        grid-template-columns: 1fr;
    }
    
    .stat-number {
        font-size: 36px;
    }
    
    .quick-amounts {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .modal-content {
        padding: 30px 20px;
    }
    
    .btn-large {
        padding: 14px 35px;
        font-size: 15px;
    }
    
    .trust-badges {
        flex-direction: column;
        align-items: center;
    }
}
